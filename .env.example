# ── Database ──────────────────────────────────────────────────────────────────
# On Railway: set this to your PostgreSQL plugin URL (auto-provided by Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Monitored URLs ────────────────────────────────────────────────────────────
TARGET_URLS=https://indianbank.bank.in/departments/empanelments/,https://sbi.bank.in/web/sbi-in-the-news/empanelment-of-vendors

# ── Scheduler ────────────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15
REQUEST_TIMEOUT_SECONDS=60
SCHEDULER_TIMEZONE=Asia/Kolkata
RUN_ON_STARTUP=true
HISTORY_PAGE_SIZE=30

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-secret
# On Railway: set this to your Railway public URL e.g. https://yourapp.up.railway.app
DASHBOARD_BASE_URL=https://yourapp.up.railway.app

# ── Email (Gmail App Password) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
ALERT_FROM_EMAIL=your-gmail@gmail.com
ALERT_TO_EMAILS=recipient1@email.com,recipient2@email.com
