# You can seed one or many websites at startup (comma-separated)
TARGET_URLS=https://example.com,https://example.org/blog

# Legacy single URL seed is still supported (optional)
TARGET_URL=
CHECK_INTERVAL_MINUTES=15
REQUEST_TIMEOUT_SECONDS=30
REQUEST_USER_AGENT=WebsiteMonitorBot/1.0 (+https://railway.app/)
SCHEDULER_TIMEZONE=UTC
RUN_ON_STARTUP=true
HISTORY_PAGE_SIZE=30
DASHBOARD_BASE_URL=http://localhost:5000
FLASK_SECRET_KEY=replace-with-a-random-secret-key

# Use Railway PostgreSQL in cloud. Leave DATABASE_URL empty locally to use sqlite fallback.
DATABASE_URL=
SQLITE_PATH=data/monitor.db

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=yourgmail@gmail.com
SMTP_PASSWORD=your-16-char-gmail-app-password
SMTP_USE_TLS=true
ALERT_FROM_EMAIL=yourgmail@gmail.com
ALERT_TO_EMAILS=you@example.com,team@example.com
